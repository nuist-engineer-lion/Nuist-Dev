---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getAssetPath } from "@/utils/withBase";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const brands: {
  name: string;
  description: string;
  href: string;
  image?: string;
  emoji?: string;
}[] = [
  {
    name: "修机师 Lion",
    description: "硬件维修、装机升级与电脑故障排查服务",
    href: "https://wiki.nuist.link/",
    image: getAssetPath("lion/logo-lion-450.jpg"),
  },
  {
    name: "多火 DuoHuo",
    description: "互联网产品开发、全栈工程与技术写作",
    href: "https://docs.duohuo.org.cn",
    image: getAssetPath("duohuo/logo-girl-450.avif"),
  },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section
      id="brands"
      class="grid grid-cols-1 gap-4 pt-12 pb-6 sm:grid-cols-2"
    >
      {
        brands.map(brand => (
          <a
            href={brand.href}
            {...(brand.href.startsWith("http")
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
            class="group border-border bg-background hover:border-accent flex items-center gap-4 rounded-lg border p-5 transition-colors"
          >
            <div class="bg-muted text-accent flex size-16 shrink-0 items-center justify-center overflow-hidden rounded-full text-3xl">
              {"image" in brand && brand.image ? (
                <img
                  src={brand.image}
                  alt=""
                  width="450"
                  height="450"
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span aria-hidden="true">{brand.emoji ?? ""}</span>
              )}
            </div>
            <div class="min-w-0">
              <h3 class="group-hover:text-accent text-lg font-semibold transition-colors">
                {brand.name}
              </h3>
              <p class="text-muted-foreground mt-1 text-sm">
                {brand.description}
              </p>
            </div>
          </a>
        ))
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
