---
type Props = {
  owner: string;
  repo: string;
  url: string;
  description?: string;
  language?: string;
  languageColor?: string;
  stars?: number;
  forks?: number;
  license?: string;
};

const {
  owner,
  repo,
  url,
  description,
  language,
  languageColor = "#dea584",
  stars = 0,
  forks = 0,
  license,
} = Astro.props;

const fmt = (n: number) => (n >= 1000 ? `${(n / 1000).toFixed(1)}k` : `${n}`);
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="gh-bookmark group"
>
  <span class="gh-bookmark-grid">
    <svg
      class="gh-bookmark-icon"
      viewBox="0 0 16 16"
      width="20"
      height="20"
      aria-hidden="true"
      fill="currentColor"
    >
      <path
        d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.2.73.95.91 1.33.18.37.71 1.1 2.2.7.02.45.03.81.05 1.04 0 .21-.15.45-.55.38A8.013 8.013 0 0 1 0 8c0-4.42 3.58-8 8-8"
      ></path>
    </svg>

    <span class="gh-bookmark-titles">
      <span class="gh-bookmark-owner">{owner}/</span>
      <span class="gh-bookmark-repo">{repo}</span>
    </span>
  </span>

  {description && <span class="gh-bookmark-desc">{description}</span>}

  <span class="gh-bookmark-meta">
    {
      language && (
        <span class="gh-bookmark-meta-item">
          <span
            class="gh-bookmark-lang-dot"
            style={`background:${languageColor}`}
          />
          {language}
        </span>
      )
    }
    {stars > 0 && <span class="gh-bookmark-meta-item">★ {fmt(stars)}</span>}
    {forks > 0 && <span class="gh-bookmark-meta-item">⑂ {fmt(forks)}</span>}
    {license && <span class="gh-bookmark-meta-item">{license}</span>}
  </span>
</a>

<style>
  .gh-bookmark {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.625rem;
    background: var(--background);
    color: var(--foreground);
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }

  .gh-bookmark:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -4px rgba(0, 0, 0, 0.15);
  }

  .gh-bookmark:visited {
    color: var(--foreground);
  }

  .gh-bookmark-grid {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .gh-bookmark-icon {
    color: var(--muted-foreground);
    flex-shrink: 0;
    transition: color 0.15s ease;
  }

  .gh-bookmark:hover .gh-bookmark-icon {
    color: var(--foreground);
  }

  .gh-bookmark-titles {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.15rem;
    min-width: 0;
  }

  .gh-bookmark-owner {
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  .gh-bookmark-repo {
    color: var(--accent);
    font-weight: 600;
    font-size: 1rem;
    word-break: break-all;
  }

  .gh-bookmark:hover .gh-bookmark-repo {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .gh-bookmark-desc {
    color: var(--foreground);
    font-size: 0.9rem;
    line-height: 1.45;
    margin: 0;
  }

  .gh-bookmark-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    font-size: 0.8rem;
    color: var(--muted-foreground);
  }

  .gh-bookmark-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .gh-bookmark-lang-dot {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    .gh-bookmark {
      transition: none;
    }
    .gh-bookmark:hover {
      transform: none;
    }
  }
</style>
